# LLM — required
GOOGLE_API_KEY=

# Observability — all optional. LangSmith activates only when LANGSMITH_API_KEY is set.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=research-assistant
OTEL_EXPORTER_OTLP_ENDPOINT=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | pretty (use pretty for local dev)

# Research backend — "tavily" (default) hits live web search; "mock" uses data/mock_companies.py
RESEARCH_BACKEND=tavily
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=8

# Retrieval quality (Tier 2)
QUERY_REWRITE_ENABLED=true
RERANK_ENABLED=true
RERANK_MODEL=ms-marco-MiniLM-L-12-v2
RERANK_TOP_K=5

# Long-term memory (Tier 4) — per-user fact store across threads
LONGTERM_MEMORY_ENABLED=true
LONGTERM_MEMORY_TOP_K=3

# Caps — single enforcement site lives in src/graph/routing.py / config.py
MAX_RESEARCH_ATTEMPTS=3
MAX_TOOL_CALLS_PER_NODE=5
LLM_RETRY_MAX_ATTEMPTS=4

# Models — flash for easy tasks, pro for complex reasoning (QA + thinking)
MODEL_PRIMARY=gemini-2.5-flash
MODEL_QA=gemini-2.5-pro

# Cost ceiling per run (USD)
COST_CEILING_PER_RUN_USD=0.10
